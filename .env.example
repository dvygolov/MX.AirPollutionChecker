# Токен бота МАХ (получается в личном кабинете разработчика)
MAX_BOT_TOKEN=*** xxxxxx

# API база (опционально, по умолчанию platform-api.max.ru)
MAX_API_BASE=https://platform-api.max.ru

# Порог превышения ПДК (доля от ПДК, >1.0 = превышение)
FACTOR_THRESHOLD=1.0

# Интервал проверки в секундах (минимум 30)
POLL_INTERVAL_SEC=300

# Список отслеживаемых веществ (через запятую). Пусто = все.
# ID: 9=NO, 10=NO2, 11=NH3, 12=SO2, 13=H2S, 14=CO, 59=C1-C5, 60=C6-C10
# WATCHED_MEAS_IDS=9,10,12,13

# SQLite-база
STATE_DB_PATH=bot_state.db

# Уровень логирования
LOG_LEVEL=INFO
